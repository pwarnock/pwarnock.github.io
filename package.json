{
  "name": "pwarnock-monorepo",
  "version": "0.20.3",
  "private": true,
  "description": "Peter Warnock's personal website - monorepo with Hugo, TypeScript agents, and QA tooling",
  "type": "module",
  "workspaces": [
    "packages/*",
    "shared"
  ],
  "scripts": {
    "build": "bun run --filter @pwarnock/site build && cp packages/site/public/tools/index.json packages/site/public/tools/radar.json",
    "clean": "bun run --filter @pwarnock/site clean",
    "dev": "bun run --filter @pwarnock/site dev",
    "dev:legacy": "bun run --filter @pwarnock/site dev:legacy",
    "build:production": "bun run --filter @pwarnock/site build && cp packages/site/public/tools/index.json packages/site/public/tools/radar.json",
    "css:build": "echo 'CSS is handled by Hugo build process'",
    "css:watch": "cd packages/site && bun x @tailwindcss/cli -i ./assets/css/main.css -o ./static/css/main.css --postcss --watch",
    "analyze": "cd packages/site && hugo --gc --minify --enableGitInfo && cd ../.. && bun run analyze:bundles",
    "lint": "bun run lint:yaml && bun run lint:toml && bun run lint:css",
    "lint:check": "bun x stylelint \"packages/site/assets/css/**/*.css\" \"packages/site/static/css/**/*.css\"",
    "format": "bun x prettier --write .",
    "format:check": "bun x prettier --check .",
    "lint:yaml": "mise exec -- actionlint",
    "lint:toml": "bun x @taplo/cli lint **/*.toml",
    "lint:css": "bun x stylelint \"**/*.css\" --ignore-path .gitignore",
    "validate": "./scripts/validate.sh",
    "validate:links": "./scripts/validate-links.sh",
    "validate:portfolio": "bun run portfolio-validate",
    "test:ga": "bun run test-ga",
    "postinstall": "bun x husky",
    "generate-version": "bun run ./packages/tooling/scripts/build/generate-version.js",
    "portfolio-validate": "bun run ./scripts/validate-portfolio-frontmatter.js",
    "test-ga": "bun run ./scripts/test-ga-tracking.js",
    "test-security": "bun run ./scripts/test-security.js",
    "verify:cdn": "./scripts/verify-cdn-integrity.sh",
    "build:preview": "bun run --filter @pwarnock/site build:preview",
    "test": "vitest --run",
    "test:e2e": "bunx playwright test",
    "test:visual": "bunx playwright test --grep @visual",
    "test:bdd": "cd test && ./run-tests.sh",
    "test:bdd:ci": "cd test && ./run-tests.sh ci",
    "serve:preview": "bun run build:preview && bunx serve packages/site/public -p 3000 -s",
    "version:patch": "bun pm version patch && ./scripts/version-sync.sh",
    "version:minor": "bun pm version minor && ./scripts/version-sync.sh",
    "version:major": "bun pm version major && ./scripts/version-sync.sh",
    "version:sync": "./scripts/version-sync.sh",
    "version:dev": "./scripts/version-dev.sh",
    "version:release": "./scripts/release-prep.sh",
    "dev:start": "./scripts/dev-cycle-start.sh",
    "release:prep": "./scripts/release-prep.sh",
    "perf:monitor": "./scripts/performance-monitor.sh",
    "perf:analyze": "hugo --gc --minify --enableGitInfo && echo '📊 Build stats generated in hugo_stats.json'",
    "test:dev": "./scripts/dev-test-runner.sh",
    "test:watch": "./scripts/dev-test-runner.sh --watch",
    "test:unit": "./scripts/run-all-unit-tests.sh",
    "test:unit:watch": "./scripts/run-all-unit-tests.sh --watch",
    "dev:worktree": "./scripts/worktree-dev.sh",
    "dev:worktree-simple": "./scripts/worktree-simple.sh",
    "test:worktree": "./scripts/worktree-tests.sh",
    "test:unit:go": "cd test && go test -v ./support/...",
    "test:unit:ts": "vitest --run",
    "test:unit:ts:watch": "vitest --watch",
    "test:unit:ui": "vitest --ui",
    "test:coverage": "./scripts/run-all-unit-tests.sh --coverage",
    "test:coverage:ts": "vitest --coverage --run",
    "test:deployment": "./test/deployment_validation.test.sh",
    "test:deployment:integration": "./test/deployment_workflow.integration.sh",
    "test:e2e:watch": "./scripts/dev-test-runner.sh --watch e2e",
    "test:visual:watch": "./scripts/dev-test-runner.sh --watch visual",
    "test:perf:watch": "./scripts/dev-test-runner.sh --watch performance",
    "build:path": "./scripts/path-based-build.sh",
    "build:content": "./scripts/path-based-build.sh --force",
    "build:infra": "./scripts/path-based-build.sh --force",
    "deploy:staging": "./scripts/deploy-staging.sh",
    "deploy:production": "./scripts/deploy-production.sh",
    "sync:env": "./scripts/sync-environments.sh",
    "setup:branch-protection": "./scripts/setup-branch-protection.sh",
    "validate:deployment": "./scripts/validate-deployment.sh",
    "test:environment": "./scripts/test-environment.sh",
    "env:staging": "git checkout staging",
    "env:production": "git checkout production",
    "env:main": "git checkout main",
    "analyze:bundles": "bun run ./scripts/analyze-bundles.js",
    "bundle:protection": "bun run ./scripts/bundle-size-protection.js",
    "load:test": "bun run ./scripts/load-testing-with-flag.js",
    "qa:auto": "bun run ./packages/qa-tools/src/qaCli.ts auto",
    "qa:content": "bun run ./packages/qa-tools/src/qaCli.ts content",
    "qa:full": "bun run ./packages/qa-tools/src/qaCli.ts full",
    "sync:backlog-to-beads": "bun run ./scripts/sync/backlog-to-beads.js",
    "sync:beads-to-cody": "bun run ./scripts/sync/beads-to-cody.js",
    "sync:release-notes": "bun run ./scripts/sync/release-notes-generator.js",
    "status:dashboard": "bun run ./scripts/status-dashboard.ts",
    "degit:refresh": "bun run ./scripts/degit-refresh.sh",
    "agent:blog": "bun run ./packages/agents/src/cli/agent-cli.ts blog",
    "agent:portfolio": "bun run ./packages/agents/src/cli/agent-cli.ts portfolio",
    "agent:radar": "bun run ./packages/agents/src/cli/agent-cli.ts radar",
    "agent:help": "bun run ./packages/agents/src/cli/agent-cli.ts help"
  },
  "keywords": [],
  "author": "Pete Warnock",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/js": "^10.0.0",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/cli": "^4.1.18",
    "@taplo/cli": "^0.7.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "axe-playwright": "^2.2.2",
    "daisyui": "^5.5.14",
    "eslint-config-prettier": "^9.1.2",
    "eslint-formatter-compact": "^9.0.1",
    "eslint-plugin-security": "^3.0.1",
    "happy-dom": "^20.3.9",
    "husky": "^9.1.7",
    "js-yaml": "4.1.1",
    "markdownlint-cli": "^0.46.0",
    "minimatch": "^10.1.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "serve": "^14.2.5",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.208.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/sdk-trace-base": "^2.5.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "logfire": "^0.11.1",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.1.18",
    "ws": "^8.19.0"
  },
  "resolutions": {
    "ws": "^8.17.1",
    "tar-fs": "^2.1.4",
    "tmp": "^0.2.3",
    "cookie": "^0.7.0",
    "js-yaml": "4.1.1",
    "lodash": "^4.17.21"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild",
    "protobufjs"
  ]
}
